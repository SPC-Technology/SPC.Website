{
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5084"
      }
    }
  },
  "Downloads": {
    "RootPath": "C:\\Soft\\tools",
    "Title": "Public Downloads",
    "AllowedExtensions": [],
    "UploadApiKey": "spc-upload-api",
    "UploadMaxRequestBodyBytes": 1073741824
  },
  "SendGrid": {    
    "FromEmail": "no-reply@spc-technology.com",
    "FromName": "Web Form",
    "ToEmail": "tung@spc-technology.com,nghianh@spc-technology.com,support@spc-technology.com,support@spc-technology.vn"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/spc-website-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "shared": true,
          "flushToDiskInterval": "00:00:01"
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  },
  "AllowedHosts": "*"
}
