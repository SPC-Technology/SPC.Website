@page "/"
@layout MainLayout

<PageTitle>Phoebus ERP | SPC Technology</PageTitle>

<section class="hero">
    <div class="container">
        <div class="hero-grid">
            <div class="hero__content">
                <p class="eyebrow">Phoebus ERP by SPC Technology</p>
                <h1>Phoebus ERP by SPC Technology</h1>
                <p class="lead">
                    Phoebus ERP is a business software platform developed and delivered by SPC Technology.
                    It helps companies manage finance, accounting, inventory, purchasing, sales, and reporting in one system.
                </p>
                <div class="hero-notes">
                    <span class="hero-note">Integrated ERP platform</span>
                    <span class="hero-note">Implementation and support</span>
                    <span class="hero-note">Built for real operations</span>
                </div>
                <div class="actions">
                    <a class="button button--primary" href="/demo">Request Demo</a>
                    <a class="button button--secondary" href="/contact">Contact Sales</a>
                </div>
            </div>

            <div class="hero-visual">
                <div class="product-preview">
                    <img src="/images/phoebus-modules.png"
                         alt="Phoebus ERP Modules"
                         class="product-preview__image" />
                </div>
            </div>
        </div>
    </div>
</section>

<section class="trust-strip">
    <div class="container">
        <div class="trust-strip__inner">
            <div class="trust-item">ERP Platform</div>
            <div class="trust-item">Implementation</div>
            <div class="trust-item">Customization</div>
            <div class="trust-item">Migration</div>
            <div class="trust-item">Support</div>
        </div>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="section-shell">
            <div class="section-header">
                <h2 class="section-title">Better Control Across Finance and Operations</h2>
                <p class="section-intro">
                    An integrated ERP system helps businesses reduce disconnected processes and improve visibility across departments.
                    Teams can work from a shared system with more consistent data, clearer workflows, and better reporting.
                </p>
            </div>
            <div class="grid grid--three">
                <article class="card card--accent">
                    <h3>Connected Processes</h3>
                    <p>Bring finance, inventory, purchasing, and sales into one operational system.</p>
                </article>
                <article class="card card--accent">
                    <h3>Clearer Reporting</h3>
                    <p>Work from more consistent data and improve operational and financial visibility.</p>
                </article>
                <article class="card card--accent">
                    <h3>Stronger Control</h3>
                    <p>Reduce duplicated effort and build a better foundation for day-to-day management.</p>
                </article>
            </div>
        </div>
    </div>
</section>

<section class="section section--alt">
    <div class="container">
        <div class="section-shell section-shell--split">
            <div class="overview-panel">
                <div class="section-header">
                    <h2 class="section-title">What Phoebus ERP Covers</h2>
                    <p class="section-intro">
                        Phoebus ERP supports the operational and financial workflows that businesses depend on every day.
                        It provides structured process support across core functions while allowing companies to work with a system
                        that can be implemented and adapted to their requirements.
                    </p>
                </div>
                <ul class="bullet-list">
                    <li>Finance and accounting management</li>
                    <li>Inventory and stock control</li>
                    <li>Purchasing and supplier processes</li>
                    <li>Sales and customer transaction workflows</li>
                    <li>Reporting for operational and management review</li>
                </ul>
            </div>
            <aside class="highlight-panel">
                <p class="highlight-panel__eyebrow">Product Focus</p>
                <h3>One platform, practical coverage</h3>
                <p>
                    SPC Technology positions Phoebus ERP as a business platform that can be deployed,
                    adapted, and supported by the same team that builds it.
                </p>
                <div class="actions">
                    <a class="button button--secondary" href="/modules">View Core Modules</a>
                </div>
            </aside>
        </div>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="section-shell">
            <div class="section-header">
                <h2 class="section-title">Core Modules</h2>
                <p class="section-intro">Phoebus ERP covers the core areas needed to manage business operations.</p>
            </div>
            <div class="grid grid--modules">
                <article class="card card--module">
                    <div class="module-icon" aria-hidden="true">
                        <img src="/images/icons/ledgeraccounting-icon.svg" alt="" class="module-icon__image" />
                    </div>
                    <h3>Finance</h3>
                    <p>Financial control, transaction processing, and visibility for management review.</p>
                </article>
                <article class="card card--module">
                    <div class="module-icon" aria-hidden="true">
                        <img src="/images/icons/fixedasset-icon.svg" alt="" class="module-icon__image" />
                    </div>
                    <h3>Accounting</h3>
                    <p>Structured accounting processes and reliable financial record management.</p>
                </article>
                <article class="card card--module">
                    <div class="module-icon" aria-hidden="true">
                        <img src="/images/icons/inventory-icon.svg" alt="" class="module-icon__image" />
                    </div>
                    <h3>Inventory</h3>
                    <p>Track stock movement, balances, and inventory oversight across operations.</p>
                </article>
                <article class="card card--module">
                    <div class="module-icon" aria-hidden="true">
                        <img src="/images/icons/purchaseorder-icon.svg" alt="" class="module-icon__image" />
                    </div>
                    <h3>Purchasing</h3>
                    <p>Support procurement workflows, supplier coordination, and purchasing control.</p>
                </article>
                <article class="card card--module">
                    <div class="module-icon" aria-hidden="true">
                        <img src="/images/icons/saleorder-icon.svg" alt="" class="module-icon__image" />
                    </div>
                    <h3>Sales</h3>
                    <p>Manage sales transactions and maintain a clearer operational process flow.</p>
                </article>
                <article class="card card--module">
                    <div class="module-icon" aria-hidden="true">
                        <img src="/images/icons/document-icon.svg" alt="" class="module-icon__image" />
                    </div>
                    <h3>Reporting</h3>
                    <p>Access operational and management reporting across key business areas.</p>
                </article>
            </div>
            <div class="actions">
                <a class="button button--secondary" href="/modules">View Modules</a>
            </div>
        </div>
    </div>
</section>

<section class="section section--alt">
    <div class="container">
        <div class="section-shell">
            <div class="section-header">
                <h2 class="section-title">Implementation, Customization, and Ongoing Support</h2>
                <p class="section-intro">
                    SPC Technology provides the services required to put Phoebus ERP into practical use.
                    This includes implementation planning, system customization, migration from existing systems,
                    user training, and ongoing support after go-live.
                </p>
            </div>
            <div class="grid grid--four">
                <article class="card card--service">
                    <div class="module-icon" aria-hidden="true">
                        <img src="/images/icons/implement-icon.svg" alt="" class="module-icon__image" />
                    </div>
                    <h3>Implementation</h3>
                    <p>Plan rollout, configure the system, and support adoption across the business.</p>
                </article>
                <article class="card card--service">
                    <div class="module-icon" aria-hidden="true">
                        <img src="/images/icons/intergration-icon.svg" alt="" class="module-icon__image" />
                    </div>
                    <h3>Customization</h3>
                    <p>Adapt the platform to operational requirements where standard processes need extension.</p>
                </article>
                <article class="card card--service">
                    <div class="module-icon" aria-hidden="true">
                        <img src="/images/icons/download-icon.svg" alt="" class="module-icon__image" />
                    </div>
                    <h3>Migration</h3>
                    <p>Support transition from existing systems, data sources, and working processes.</p>
                </article>
                <article class="card card--service">
                    <div class="module-icon" aria-hidden="true">
                        <img src="/images/icons/trainingsupport-icon.svg" alt="" class="module-icon__image" />
                    </div>
                    <h3>Training</h3>
                    <p>Prepare users and teams to work effectively with Phoebus ERP after go-live.</p>
                </article>
            </div>
            <div class="actions">
                <a class="button button--secondary" href="/services">View Services</a>
                <a class="button button--primary" href="/contact">Contact Sales</a>
            </div>
        </div>
    </div>
</section>

