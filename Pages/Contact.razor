@page "/contact"
@layout MainLayout

<PageTitle>Contact | SPC Technology</PageTitle>

<section class="section">
    <div class="container">
        <div class="contact-layout">
            <div class="section-shell">
                <p class="eyebrow">Contact</p>
                <h1>Request a Demo or Contact Sales</h1>
                <p class="lead">
                    Contact SPC Technology to discuss Phoebus ERP, implementation requirements, support routing, or general business enquiries.
                </p>
                <p>
                    Use the demo request form if you want a product walkthrough. For sales or implementation discussions,
                    this page acts as the direct contact point for the SPC Technology team.
                </p>
                <ul>
                    <li>Product and sales enquiries</li>
                    <li>Implementation and customization discussions</li>
                    <li>Support routing and customer contact</li>
                    <li>General business contact details</li>
                </ul>
                <div class="contact-details">
                    <p><strong>SPC Technology</strong></p>
                    <p>Unit 0206, Floor 2, Block A, Lexington Office, 67 Mai Chi Tho St., An Phu Ward, District 2, HCMC, Vietnam</p>
                    <p>(+84) 28 7307 6896</p>
                    <p>support@spc-technology.vn</p>
                </div>
                <div class="actions">
                    <a class="button button--secondary" href="/demo">Request Demo</a>
                </div>
            </div>

            <div class="section-shell">
                <p class="eyebrow">Office Location</p>
                <h2>Visit Our Office</h2>
                <p class="section-intro">
                    SPC Technology office location shown on Google Maps.
                </p>
                <OfficeMap />
            </div>
        </div>
    </div>
</section>
